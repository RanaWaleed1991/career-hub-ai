# ============================================================================
# PRODUCTION ENVIRONMENT VARIABLES - Frontend
# ============================================================================
# IMPORTANT: Copy this file to .env.production and fill in your actual values
# DO NOT commit .env.production to git (it contains secrets)
# ============================================================================

# Supabase Configuration (PRODUCTION PROJECT)
# Get these from your NEW production Supabase project dashboard
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-production-anon-key

# Stripe Configuration (PRODUCTION PUBLISHABLE KEY)
# IMPORTANT: Use pk_live_... key for production, NOT pk_test_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# API Configuration
VITE_API_URL=https://your-production-api-domain.com/api

# ============================================================================
# SECURITY CHECKLIST:
# ============================================================================
# [ ] Changed VITE_SUPABASE_URL to NEW production project
# [ ] Changed VITE_SUPABASE_ANON_KEY to NEW production project
# [ ] Changed Stripe key from test (pk_test_) to live (pk_live_)
# [ ] Updated VITE_API_URL to production API domain
# [ ] Verified .env.production is in .gitignore
# ============================================================================
