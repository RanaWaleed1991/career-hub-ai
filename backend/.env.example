# Backend Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================================================
# NODE CONFIGURATION
# ============================================================================
# Node Environment (development, production, test)
NODE_ENV=development

# Server Port
PORT=3001

# Frontend URL for CORS (your React app URL)
FRONTEND_URL=http://localhost:5173

# ============================================================================
# GOOGLE GEMINI AI CONFIGURATION (REQUIRED)
# ============================================================================
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================================
# SUPABASE CONFIGURATION (REQUIRED)
# ============================================================================
# Get these from your Supabase project settings: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ============================================================================
# STRIPE PAYMENT CONFIGURATION (REQUIRED)
# ============================================================================
# Get these from your Stripe Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_ID=price_your_subscription_price_id_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Stripe Product Price IDs (REQUIRED for payments)
# Create products in Stripe Dashboard and add the price IDs here
STRIPE_PRICE_ID_PRO_WEEKLY=price_your_weekly_price_id_here
STRIPE_PRICE_ID_PRO_MONTHLY=price_your_monthly_price_id_here
STRIPE_PRICE_ID_EXPERT_REVIEW=price_your_expert_review_price_id_here

# Adzuna Job API Configuration (REQUIRED for job search)
# Get your API credentials from: https://developer.adzuna.com/
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_APP_KEY=your_adzuna_app_key_here

# ============================================================================
# SENDGRID EMAIL CONFIGURATION (REQUIRED for password reset, welcome emails)
# ============================================================================
# Get your API key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# Email sender configuration
EMAIL_FROM=careerhubaiaus@gmail.com
EMAIL_FROM_NAME=Career Hub AI

# Server Port (optional, defaults to 3001)
PORT=3001

# Frontend URL for CORS (optional, defaults to http://localhost:5173)
FRONTEND_URL=http://localhost:5173

# Node Environment (optional, defaults to development)
NODE_ENV=development
