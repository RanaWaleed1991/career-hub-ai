# ============================================================================
# PRODUCTION ENVIRONMENT VARIABLES - Backend
# ============================================================================
# IMPORTANT: Copy this file to .env.production and fill in your actual values
# DO NOT commit .env.production to git (it contains secrets)
# ============================================================================

# Server Configuration
NODE_ENV=production
PORT=3001
CLIENT_URL=https://your-production-domain.com

# Supabase Configuration (PRODUCTION PROJECT)
# Get these from your NEW production Supabase project dashboard
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-production-service-role-key
SUPABASE_ANON_KEY=your-production-anon-key

# Stripe Configuration (PRODUCTION KEYS)
# IMPORTANT: Use sk_live_... keys for production, NOT sk_test_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# Adzuna API
ADZUNA_APP_ID=your-app-id
ADZUNA_API_KEY=your-api-key

# Google Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# ============================================================================
# SECURITY CHECKLIST:
# ============================================================================
# [ ] Changed SUPABASE_URL to NEW production project
# [ ] Changed SUPABASE_SERVICE_ROLE_KEY to NEW production project
# [ ] Changed SUPABASE_ANON_KEY to NEW production project
# [ ] Changed Stripe keys from test (sk_test_) to live (sk_live_)
# [ ] Updated CLIENT_URL to production domain
# [ ] Verified .env.production is in .gitignore
# ============================================================================
